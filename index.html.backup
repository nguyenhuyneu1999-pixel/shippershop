</div>
<section class="hero">
        <div class="container">
            <div class="hero-content fade-in">
                <h1>🎉 Siêu Sale Mỗi Ngày</h1>
                <p>Giảm giá đến 50% - Freeship toàn quốc - Voucher hấp dẫn</p>
                <div style="display: flex; gap: 15px; margin-top: 30px;">
                    <a href="shop.html" class="btn btn-primary">Mua sắm ngay <i class="fas fa-arrow-right"></i></a>
                    <a href="#flash-sale" class="btn btn-secondary">Flash Sale hôm nay</a>
                </div>
            </div>
        </div>
    </section>

    <!-- CATEGORIES -->
    <section class="products-section" style="padding-top: 40px;">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title">Danh mục nổi bật</h2>
                <p class="section-subtitle">Khám phá ngay</p>
            </div>

            <div class="products-grid" style="grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));">
                <div class="product-card" onclick="location.href='shop.html?category=dien-thoai'">
                    <div class="product-image">
                        <img src="https://via.placeholder.com/300x300/EE4D2D/FFFFFF?text=Dien+Thoai" alt="Điện thoại">
                    </div>
                    <div class="product-info">
                        <h3 class="product-name" style="text-align: center;">📱 Điện Thoại</h3>
                    </div>
                </div>

                <div class="product-card" onclick="location.href='shop.html?category=laptop'">
                    <div class="product-image">
                        <img src="https://via.placeholder.com/300x300/FF8C00/FFFFFF?text=Laptop" alt="Laptop">
                    </div>
                    <div class="product-info">
                        <h3 class="product-name" style="text-align: center;">💻 Laptop</h3>
                    </div>
                </div>

                <div class="product-card" onclick="location.href='shop.html?category=thoi-trang'">
                    <div class="product-image">
                        <img src="https://via.placeholder.com/300x300/FFB84D/FFFFFF?text=Thoi+Trang" alt="Thời trang">
                    </div>
                    <div class="product-info">
                        <h3 class="product-name" style="text-align: center;">👕 Thời Trang</h3>
                    </div>
                </div>

                <div class="product-card" onclick="location.href='shop.html?category=my-pham'">
                    <div class="product-image">
                        <img src="https://via.placeholder.com/300x300/D73211/FFFFFF?text=My+Pham" alt="Mỹ phẩm">
                    </div>
                    <div class="product-info">
                        <h3 class="product-name" style="text-align: center;">💄 Mỹ Phẩm</h3>
                    </div>
                </div>

                <div class="product-card" onclick="location.href='shop.html?category=gia-dung'">
                    <div class="product-image">
                        <img src="https://via.placeholder.com/300x300/00C851/FFFFFF?text=Gia+Dung" alt="Gia dụng">
                    </div>
                    <div class="product-info">
                        <h3 class="product-name" style="text-align: center;">🏠 Gia Dụng</h3>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- FLASH SALE -->
    <section class="products-section" id="flash-sale" style="background: linear-gradient(135deg, #EE4D2D 0%, #D73211 100%);">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title" style="color: white;">⚡ Flash Sale</h2>
                <p class="section-subtitle" style="color: rgba(255,255,255,0.9);">Kết thúc trong: <span id="countdown" style="font-weight: bold; font-size: 24px;">02:45:30</span></p>
            </div>
            <div class="products-grid" id="flashSaleProducts"></div>
        </div>
    </section>

    <!-- FEATURED PRODUCTS -->
    <section class="products-section">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title">Sản phẩm nổi bật</h2>
            </div>
            <div class="products-grid" id="featuredProducts"></div>
            <div style="text-align: center; margin-top: 40px;">
                <a href="shop.html" class="btn btn-primary">Xem tất cả <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>
    </section>

    <!-- FOOTER -->
    <footer style="background: var(--dark); color: white; padding: 60px 0 20px;">
        <div class="container">
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 40px;">
                <div>
                    <h3 style="margin-bottom: 20px;">🛒 SHIPPERSHOP</h3>
                    <p style="color: rgba(255,255,255,0.7);">Nền tảng mua sắm trực tuyến #1</p>
                </div>
                <div>
                    <h4 style="margin-bottom: 20px;">Liên hệ</h4>
                    <p style="color: rgba(255,255,255,0.7);">📞 1900-6868</p>
                    <p style="color: rgba(255,255,255,0.7);">📧 <a href="/cdn-cgi/l/email-protection" class="__cf_email__" data-cfemail="d5a6a0a5a5baa7a195a6bdbca5a5b0a7a6bdbaa5fba3bb">[email&#160;protected]</a></p>
                </div>
            </div>
                <p style="color: rgba(255,255,255,0.5);">&copy; 2024 ShipperShop. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script src="js/shop.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Load products
            const flashContainer = document.getElementById('flashSaleProducts');
            const featuredContainer = document.getElementById('featuredProducts');
            if (flashContainer && typeof PRODUCTS !== 'undefined') {
                flashContainer.innerHTML = PRODUCTS.slice(0,4).map(createProductCard).join('');
            }
            if (featuredContainer && typeof PRODUCTS !== 'undefined') {
                featuredContainer.innerHTML = PRODUCTS.filter(p=>p.featured).map(createProductCard).join('');
            }
            // Countdown
            const el = document.getElementById('countdown');
            if (el) {
                let h=2,m=45,s=30;
                setInterval(()=>{
                    s--; if(s<0){s=59;m--;} if(m<0){m=59;h--;} if(h<0)h=23;
                    el.textContent = String(h).padStart(2,'0')+':'+String(m).padStart(2,'0')+':'+String(s).padStart(2,'0');
                },1000);
            }
            // Cart count
            const cart = JSON.parse(localStorage.getItem('cart')||'[]');
            const cc = document.getElementById('cartCount');
            if(cc) cc.textContent = cart.reduce((s,i)=>s+(i.quantity||1),0);
            // Auth
            const user = JSON.parse(localStorage.getItem('user')||'null');
            const ab = document.getElementById('authBtn');
            if(user && ab){ ab.innerHTML='<i class="fas fa-user-circle"></i><span>'+user.fullname+'</span>'; ab.href='profile.html'; }
            // Search
            const si = document.getElementById('searchInput');
            if(si) si.addEventListener('keypress', e=>{ if(e.key==='Enter'&&si.value.trim()) window.location.href='shop.html?search='+encodeURIComponent(si.value.trim()); });
        });
        function searchProducts(){ const v=document.getElementById('searchInput').value.trim(); if(v) window.location.href='shop.html?search='+encodeURIComponent(v); }
    </script>
  <!-- MOBILE BOTTOM NAV -->
  <nav id="mobileBottomNav" role="navigation" aria-label="Mobile navigation">
    <a href="index.html"     class="mnav-item" data-page="index.html">
      <i class="fas fa-home"></i><span>Trang chủ</span>
    </a>
    <a href="shop.html"      class="mnav-item" data-page="shop.html" style="position:relative">
      <i class="fas fa-store"></i>
      <span class="mnav-badge" id="navCartBadge" style="display:none">0</span>
      <span>Mua sắm</span>
    </a>
    <button class="mnav-item mnav-fab-wrap" onclick="handleFab()" aria-label="Hành động nhanh">
      <div class="mnav-fab"><i class="fas fa-search" id="fabIcon"></i></div>
    </button>
    <a href="community.html" class="mnav-item" data-page="community.html">
      <i class="fas fa-users"></i><span>Cộng đồng</span>
    </a>
    <a href="profile.html"   class="mnav-item" data-page="profile.html" id="navProfileItem">
      <i class="fas fa-user" id="navProfileIcon"></i><span id="navProfileName">Tài khoản</span>
    </a>
  </nav>
  <button id="backToTop" onclick="scrollToTop()" aria-label="Lên đầu trang">
    <i class="fas fa-chevron-up"></i>
  </button>
  <div id="pullIndicator" aria-hidden="true">
    <i class="fas fa-rotate-right"></i>
    <span>Kéo xuống để làm mới</span>
  </div>
  <script src="js/mobile.js"></script>
</body>
</html>