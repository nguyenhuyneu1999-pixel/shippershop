      <div style="width:44px;height:44px;background:#FFF3EF;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20px">📱</div>Điện Thoại
    </a>
    <a href="shop.html?cat=laptop" style="display:flex;flex-direction:column;align-items:center;gap:4px;text-decoration:none;color:#333;flex-shrink:0;min-width:56px;font-size:11px;font-weight:600">
      <div style="width:44px;height:44px;background:#FFF3EF;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20px">💻</div>Laptop
    </a>
    <a href="shop.html?cat=thoi-trang" style="display:flex;flex-direction:column;align-items:center;gap:4px;text-decoration:none;color:#333;flex-shrink:0;min-width:56px;font-size:11px;font-weight:600">
      <div style="width:44px;height:44px;background:#FFF3EF;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20px">👗</div>Thời trang
    </a>
    <a href="shop.html?cat=my-pham" style="display:flex;flex-direction:column;align-items:center;gap:4px;text-decoration:none;color:#333;flex-shrink:0;min-width:56px;font-size:11px;font-weight:600">
      <div style="width:44px;height:44px;background:#FFF3EF;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20px">💄</div>Mỹ phẩm
    </a>
    <a href="shop.html?cat=gia-dung" style="display:flex;flex-direction:column;align-items:center;gap:4px;text-decoration:none;color:#333;flex-shrink:0;min-width:56px;font-size:11px;font-weight:600">
      <div style="width:44px;height:44px;background:#FFF3EF;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20px">🏠</div>Gia dụng
    </a>
    <a href="shop.html?cat=dien-tu" style="display:flex;flex-direction:column;align-items:center;gap:4px;text-decoration:none;color:#333;flex-shrink:0;min-width:56px;font-size:11px;font-weight:600">
      <div style="width:44px;height:44px;background:#FFF3EF;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20px">🎧</div>Điện tử
    </a>
    <a href="shop.html" style="display:flex;flex-direction:column;align-items:center;gap:4px;text-decoration:none;color:#333;flex-shrink:0;min-width:56px;font-size:11px;font-weight:600">
      <div style="width:44px;height:44px;background:#EE4D2D;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20px">🛍</div>Tất cả
