    function renderComments(comments, postId) {
        if (!comments || comments.length === 0) return '<p style="text-align:center;color:#999;padding:20px;font-size:13px">Chưa có bình luận</p>';
        // Group: top-level and replies
        var top = [], replies = {};
        comments.forEach(function(c) {
            if (c.parent_id && c.parent_id > 0) {
                if (!replies[c.parent_id]) replies[c.parent_id] = [];
                replies[c.parent_id].push(c);
            } else {
                top.push(c);
            }
        });
        return top.map(function(c) {
            var av = c.user_avatar ? '<img src="'+c.user_avatar+'" style="width:32px;height:32px;border-radius:50%;object-fit:cover">' : '<div style="width:32px;height:32px;border-radius:50%;background:#e4e6eb;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700">'+(c.user_name||'U').charAt(0)+'</div>';
            var liked = c.user_liked ? ' style="color:#d32f2f;font-weight:700"' : '';
            var html = '<div style="display:flex;gap:8px;margin-bottom:12px">'
                + '<div style="flex-shrink:0">'+av+'</div>'
                + '<div style="flex:1;min-width:0">'
                + '<div style="background:#f0f2f5;border-radius:12px;padding:8px 12px;display:inline-block;max-width:100%">'
                + '<div style="font-weight:600;font-size:13px">'+escH(c.user_name||'User')+'</div>'
                + '<div style="font-size:14px;line-height:1.4;margin-top:2px">'+escH(c.content||'')+'</div>'
                + '</div>'
                + '<div style="display:flex;gap:12px;padding:2px 12px;font-size:12px;color:#65676b">'
                + '<span>'+timeAgo(c.created_at)+'</span>'
                + '<a href="#" onclick="likeComment('+c.id+',this);return false"'+liked+'>Thích'+(c.likes_count>0?' · '+c.likes_count:'')+'</a>'
                + '<a href="#" onclick="replyTo('+postId+','+c.id+',\''+escH(c.user_name||'')+'\');return false" style="color:#65676b">Trả lời</a>'
                + '</div>';
            // Render replies
            if (replies[c.id] && replies[c.id].length > 0) {
                html += '<div style="margin-top:8px;padding-left:4px">';
                replies[c.id].forEach(function(r) {
                    var rav = r.user_avatar ? '<img src="'+r.user_avatar+'" style="width:26px;height:26px;border-radius:50%;object-fit:cover">' : '<div style="width:26px;height:26px;border-radius:50%;background:#e4e6eb;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700">'+(r.user_name||'U').charAt(0)+'</div>';
                    var rliked = r.user_liked ? ' style="color:#d32f2f;font-weight:700"' : '';
                    html += '<div style="display:flex;gap:6px;margin-bottom:8px">'
                        + '<div style="flex-shrink:0">'+rav+'</div>'
                        + '<div style="flex:1">'
                        + '<div style="background:#f0f2f5;border-radius:12px;padding:6px 10px;display:inline-block">'
                        + '<div style="font-weight:600;font-size:12px">'+escH(r.user_name||'User')+'</div>'
                        + '<div style="font-size:13px;line-height:1.4">'+escH(r.content||'')+'</div>'
                        + '</div>'
                        + '<div style="display:flex;gap:10px;padding:2px 10px;font-size:11px;color:#65676b">'
                        + '<span>'+timeAgo(r.created_at)+'</span>'
                        + '<a href="#" onclick="likeComment('+r.id+',this);return false"'+rliked+'>Thích'+(r.likes_count>0?' · '+r.likes_count:'')+'</a>'
                        + '<a href="#" onclick="replyTo('+postId+','+c.id+',\''+escH(r.user_name||'')+'\');return false" style="color:#65676b">Trả lời</a>'
                        + '</div></div></div>';
                });
                html += '</div>';
            }
            html += '</div></div>';
            return html;
        }).join('');
    }
    
