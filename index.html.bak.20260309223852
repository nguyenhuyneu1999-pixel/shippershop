      if(el.id)path+='#'+el.id;
      results.push(path+' → right:'+Math.round(r.right)+'px (vw:'+vw+')');
    }
  });
  if(results.length){
    var d=document.createElement('div');
    d.style.cssText='position:fixed;bottom:70px;left:0;right:0;background:red;color:white;padding:8px;font-size:11px;z-index:99999;max-height:200px;overflow:auto';
    d.innerHTML='<b>OVERFLOW ('+results.length+'):</b><br>'+results.slice(0,15).join('<br>');
