# Disable PHP execution in uploads directory
<FilesMatch "\.ph(p[345s]?|tml)$">
  Require all denied
</FilesMatch>

# Disable directory listing
Options -Indexes

# Only allow image/video/document types
<FilesMatch "\.(jpg|jpeg|png|gif|webp|mp4|mov|webm|pdf|doc|docx)$">
  Require all granted
</FilesMatch>
